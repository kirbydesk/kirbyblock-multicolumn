{
  "content": {
    "headline-left":  { "align": "left", "level": "h2", "size": "lg" },
    "headline-right": { "align": "left", "level": "h2", "size": "lg" },
    "text-left":      { "align": "left", "size": "normal", "mode": "textarea" },
    "text-right":     { "align": "left", "size": "normal", "mode": "textarea" },
    "quote-left":     { "align": "left", "size": "lg" },
    "quote-right":    { "align": "left", "size": "lg" },
    "author-left":    { "align": "left" },
    "author-right":   { "align": "left" },
    "media-left":     { "align": "left" },
    "media-right":    { "align": "left" },
    "button-left":    { "align": "left" },
    "button-right":   { "align": "left" }
  },
  "layout": {
    "padding-top": "small",
    "padding-bottom": "small",
    "padding-left": true,
    "padding-right": true,
    "distribution-sm": "",
    "distribution-md": "dist-3-3",
    "distribution-lg": "dist-3-3",
    "distribution-xl": "dist-3-3",
    "vertical-left-position": "top",
    "vertical-right-position": "top",
    "radius-top-left": false,
    "radius-top-right": false,
    "radius-bottom-left": false,
    "radius-bottom-right": false
  },
  "style": {
    "theme": "default"
  },
  "grid": {
    "grid-size-sm": 12,
    "grid-size-md": 12,
    "grid-size-lg": 12,
    "grid-size-xl": 12,
    "grid-offset-sm": 0,
    "grid-offset-md": 0,
    "grid-offset-lg": 0,
    "grid-offset-xl": 0
  },
  "settings": {
    "block-size": "content",
    "margin-top": false,
    "margin-bottom": false
  }
}
