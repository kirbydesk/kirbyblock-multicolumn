{
  "tabs": {
  	"layout": true,
    "style": true,
    "grid": true,
    "settings": true
  },
	"fields": {
    "content": {
      "column-blocks": [ "multicolumnheadline", "multicolumntagline", "multicolumntext", "multicolumnquote", "multicolumnmedia", "multicolumnbutton" ],
      "headline": {
        "align": [ "left", "center", "right" ],
        "level": [ "h1", "h2", "h3", "h4" ],
        "sizes": [ "xs", "sm", "md", "lg", "xl", "2xl", "3xl" ]
      },
      "text": {
        "mode": [ "textarea", "writer" ],
        "align": [ "left", "center", "right" ],
        "sizes": [ "normal", "lg", "xl", "2xl", "3xl" ]
      },
      "quote": {
        "align": [ "left", "center", "right" ],
        "sizes": [ "xs", "sm", "md", "lg", "xl", "2xl", "3xl" ]
      },
      "author": {
        "align": [ "left", "center", "right" ]
      },
      "media": {
        "align": [ "left", "center", "right" ]
      },
      "button": {
        "align": [ "left", "center", "right" ]
      },
      "tagline": {
        "align": [ "left", "center", "right" ]
      }
    },
    "layout": {
      "padding": true,
      "radius": true
    },
    "style": {
      "theme": true
    },
    "settings": {
      "fragment": true,
      "block-size": true,
      "margin": true
    }
  }
}